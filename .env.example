# Copy this file to .env and fill in your keys
# cp .env.example .env

# Required: Anthropic API key for cover letters + browser agent LLM
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: browser-use cloud API (only if using their hosted browsers)
# BROWSER_USE_API_KEY=your-key-here

# Optional: override default model
# MODEL_NAME=claude-sonnet-4-20250514

# Optional: max parallel browser agents (default: 3)
# MAX_PARALLEL=3
